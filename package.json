{
  "name": "sseclone",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "overrides": {
    "postcss": "^8.5.10",
    "esbuild": "^0.25.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "worker": "tsx src/worker/index.ts",
    "fixtures": "bash scripts/make-fixtures.sh",
    "db:migrate": "mkdir -p data && drizzle-kit migrate"
  },
  "dependencies": {
    "better-sqlite3": "^12.11.1",
    "busboy": "^1.6.0",
    "drizzle-orm": "^0.45.2",
    "execa": "^10.0.0",
    "next": "16.2.10",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/busboy": "^1.5.4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "^4.1.10",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "tailwindcss": "^4",
    "tsx": "^4.23.1",
    "typescript": "^5",
    "vitest": "^4.1.10"
  }
}
